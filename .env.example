# Cloudflare API auth
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id

# Queue selector
CF_QUEUE_NAME=emails
# Optional: set directly to skip lookup by name
# CF_QUEUE_ID=

# Test email payload
TEST_FROM=Acme <noreply@twojadomena.pl>
TEST_TO=jan@example.com
TEST_SUBJECT=Queue test email
TEST_HTML=<h1>Test</h1><p>Wiadomosc testowa z queue:test</p>
# Optional
# TEST_TEXT=Test wiadomosc z queue:test
